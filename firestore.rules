rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Products ───────────────────────────────────────
    // Anyone can read products (public catalog)
    // Only admin can create/update/delete
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Orders ─────────────────────────────────────────
    // Direct client creation is disabled (forced through server-side validation /api/place-order)
    // Users can read only their own orders
    // Only admin can update orders (status changes, tracking)
    match /orders/{orderId} {
      allow create: if false; // 🔐 Forced server-side validation
      allow read:   if isAuthenticated()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false; // orders should never be deleted
    }

    // ─── Addresses ──────────────────────────────────────
    // Users can only CRUD their own addresses
    match /addresses/{addressId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated()
                                  && resource.data.userId == request.auth.uid;
    }

    // ─── Email OTPs ─────────────────────────────────────
    // Only server (admin SDK) should read/write these
    // Client SDK access denied
    match /email_otps/{otpId} {
      allow read, write: if false;
    }

    // ─── Default: deny everything else ──────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Helper Functions ───────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == 'kothurisaideepak@gmail.com';
    }
  }
}
